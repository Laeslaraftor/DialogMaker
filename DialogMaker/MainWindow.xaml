<Window x:Class="DialogMaker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:lib="clr-namespace:DialogMaker.Lib.Elements"
        xmlns:models="clr-namespace:DialogMaker.ViewModels"
        xmlns:local="clr-namespace:DialogMaker"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="1000"
        MinWidth="1000" MinHeight="400">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition MinWidth="200" MaxWidth="400" Width="0.4*"/>
            <ColumnDefinition/>
            <ColumnDefinition MinWidth="300" MaxWidth="500" Width="0.4*"/>
        </Grid.ColumnDefinitions>
        <Menu Grid.ColumnSpan="3">
            <MenuItem Header="Файл">
                <MenuItem Header="Создать"
                          Command="{Binding CreateProjectCommand}"/>
                <MenuItem Header="Открыть"
                          Command="{Binding OpenProjectCommand}"/>
                <Separator/>
                <MenuItem Header="Закрыть"
                          Command="{Binding CloseProjectCommand}"/>
            </MenuItem>
        </Menu>
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <StackPanel Orientation="Vertical">
                <Button Content="Создать набор"
                        Command="{Binding CreatePackCommand}"
                        IsEnabled="{Binding CanCreatePack}"/>
            </StackPanel>
            <TreeView Grid.Row="1" 
                      ItemsSource="{Binding DialogPacks}">
                <TreeView.ItemTemplate>
                    <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                        <lib:ProjectItemView ContextMenu="{Binding ContextMenu}"
                                             Icon="{Binding Icon}"
                                             ItemName="{Binding Name, Mode=TwoWay}"/>
                    </HierarchicalDataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>
        </Grid>
        <TabControl Grid.Row="1" Grid.Column="2">
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Глобальные ресурсы" />
                    </StackPanel>
                </TabItem.Header>
                <Grid>
                    <TextBlock Margin="12" Text="World" />
                </Grid>
            </TabItem>
            <TabItem IsSelected="True">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Языки" />
                    </StackPanel>
                </TabItem.Header>
                <DataGrid ItemsSource="{Binding Languages}" 
                          CanUserAddRows="True" CanUserDeleteRows="True"
                          AutoGenerateColumns="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Идентификатор" Binding="{Binding Id}"/>
                        <DataGridTextColumn Header="Название" Binding="{Binding Name}"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
        </TabControl>
        <!--<lib:DiagramView>
            <lib:DiagramView.Children>
                <Border Width="150" Height="150" Background="Black"
        CornerRadius="8"/>
                <Border Width="150" Height="150" Background="DarkBlue"
        CornerRadius="8"/>
            </lib:DiagramView.Children>
        </lib:DiagramView>-->
    </Grid>
</Window>
