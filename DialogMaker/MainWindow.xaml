<Window x:Class="DialogMaker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:lib="clr-namespace:DialogMaker.Lib.Elements"
        xmlns:lib2="clr-namespace:DialogMaker.Lib"
        xmlns:models="clr-namespace:DialogMaker.ViewModels"
        xmlns:local="clr-namespace:DialogMaker"
        xmlns:editor="clr-namespace:DialogMaker.Editor"
        xmlns:core="clr-namespace:DialogMaker.Core;assembly=DialogMaker.Core"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        mc:Ignorable="d"
        Title="DialogMaker" Height="800" Width="1400"
        MinWidth="1000" MinHeight="800">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome x:Name="_chrome" 
                        CaptionHeight="40"
                        UseAeroCaptionButtons="True"
                        ResizeBorderThickness="5"
                        GlassFrameThickness="-1"/>
    </shell:WindowChrome.WindowChrome>
    <Grid x:Name="_mainGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition MinWidth="250" Width="350"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Rectangle x:Name="_blurredBackground" IsHitTestVisible="False"
                   Grid.ColumnSpan="3" Grid.RowSpan="2">
            <Rectangle.Fill>
                <VisualBrush x:Name="_blurredBackgroundBrush"
                             AlignmentX="Left" AlignmentY="Top"
                             Stretch="None" ViewboxUnits="Absolute"/>
            </Rectangle.Fill>
            <Rectangle.Clip>
                <CombinedGeometry GeometryCombineMode="Exclude">
                    <CombinedGeometry.Geometry1>
                        <RectangleGeometry x:Name="_blurredBackgroundMainClipRect"/>
                    </CombinedGeometry.Geometry1>
                    <CombinedGeometry.Geometry2>
                        <RectangleGeometry x:Name="_blurredBackgroundDiagramClipRect"/>
                    </CombinedGeometry.Geometry2>
                </CombinedGeometry>
            </Rectangle.Clip>
            <Rectangle.Effect>
                <BlurEffect Radius="50"/>
            </Rectangle.Effect>
        </Rectangle>
        <Menu Grid.ColumnSpan="3" Margin="0,0,150,0">
            <MenuItem Header="Файл" shell:WindowChrome.IsHitTestVisibleInChrome="True">
                <MenuItem Header="Создать"
                          Command="{Binding CreateProjectCommand}"/>
                <MenuItem Header="Открыть"
                          Command="{Binding OpenProjectCommand}"/>
                <MenuItem Header="Сохранить"
                          Command="{Binding Project.SaveCommand}"/>
                <Separator/>
                <MenuItem Header="Экспорт"
                          Command="{Binding ExportProjectCommand}"/>
                <Separator/>
                <MenuItem Header="Закрыть"
                          Command="{Binding CloseProjectCommand}"/>
            </MenuItem>
        </Menu>
        <Border x:Name="_actionButtonsContainer" Grid.ColumnSpan="3"
                shell:WindowChrome.IsHitTestVisibleInChrome="True"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                Background="{DynamicResource SolidBackgroundFillColorQuarternaryBrush}"
                BorderBrush="{DynamicResource SolidBackgroundFillColorBaseAltBrush}" 
                CornerRadius="4" BorderThickness="4,0.5,0.5,0.5" Padding="0,2"
                Visibility="Collapsed">
            <ListView x:Name="_actionButtons" Style="{StaticResource NoSelectionListView}"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                      ScrollViewer.VerticalScrollBarVisibility="Disabled">
                <ListView.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ListView.ItemsPanel>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <MenuItem Height="30" Command="{Binding}"
                                  CommandParameter="{Binding ElementName=_itemTabs}"
                                  IsEnabled="{Binding IsEnabled}"
                                  ToolTip="{Binding ToolTip}">
                            <MenuItem.Style>
                                <Style TargetType="MenuItem" BasedOn="{StaticResource {x:Type MenuItem}}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsVisible}" Value="False">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsVisible}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </MenuItem.Style>
                            <MenuItem.Header>
                                <StackPanel Orientation="Horizontal" Margin="0,-6,0,0">
                                    <StackPanel.RenderTransform>
                                        <TranslateTransform Y="3"/>
                                    </StackPanel.RenderTransform>
                                    <TextBlock>
                                        <Run Text="{Binding Icon}" BaselineAlignment="Center"
                                             FontFamily="{StaticResource SymbolThemeFontFamily}"
                                             Foreground="{Binding Color}"/>
                                        <Run Text="{Binding Text}"/>
                                    </TextBlock>
                                </StackPanel>
                            </MenuItem.Header>
                        </MenuItem>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Border>
        <lib:ItemTabsView x:Name="_itemTabs"
                          Grid.Row="1" Grid.Column="2"
                          CurrentItemChanged="OnItemTabsCurrentItemChanged"/>
        <TabControl Grid.Row="1">
            <TabItem IsSelected="True">
                <TabItem.Header>
                    <TextBlock Text="Структура" />
                </TabItem.Header>
                <Grid Margin="4,10,4,4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <lib:EditableTextBlock Text="{Binding Project.Name, Mode=TwoWay}"
                                               FontSize="22" FontWeight="Medium"
                                               Margin="4,6" AutoEdit="True"/>
                        <Button Grid.Column="1"
                                FontFamily="{StaticResource SymbolThemeFontFamily}" 
                                Content="&#xE710;" HorizontalAlignment="Right"
                                Command="{Binding CreatePackCommand}"
                                IsEnabled="{Binding CanCreatePack}"
                                ToolTip="Создать набор" Padding="6"/>
                    </Grid>
                    <TreeView x:Name="_projectStruct" Grid.Row="1" 
                              ItemsSource="{Binding Project.Packs}"
                              SelectedItemChanged="OnProjectStructSelectedItemChanged">
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                <lib:ProjectItemView ContextMenu="{Binding ContextMenu}"
                                                     Icon="{Binding Icon}"
                                                     ItemName="{Binding Name, Mode=TwoWay}"/>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </Grid>
            </TabItem>
            <TabItem>
                <TabItem.Header>
                    <TextBlock Text="Языки" />
                </TabItem.Header>
                <Grid Margin="4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <StackPanel Visibility="{Binding DefaultLanguageVisibility}">
                        <TextBlock Text="Язык по умолчанию"
                                   FontSize="22" FontWeight="Medium"
                                   Margin="4,8"/>
                        <Border Background="{DynamicResource AccentFillColorDefaultBrush}"
                                Padding="16,0" CornerRadius="4">
                            <lib:LanguageView Margin="0,6,0,10"
                                              Foreground="{DynamicResource TextOnAccentFillColorPrimaryBrush}"
                                              LanguageId="{Binding Project.DefaultLanguage.Id}"
                                              LanguageName="{Binding Project.DefaultLanguage.Name}"
                                              ContextMenu="{Binding Project.DefaultLanguage.ContextMenu}"
                                              IdEditCommand="{Binding Project.DefaultLanguage.EditIdCommand}"
                                              IdEditCommandParameter="{Binding Project.DefaultLanguage}"
                                              NameEditCommand="{Binding Project.DefaultLanguage.EditNameCommand}"
                                              NameEditCommandParameter="{Binding Project.DefaultLanguage}"/>
                        </Border>
                    </StackPanel>
                    <Grid Grid.Row="1" Margin="0,6,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Все языки"
                                       FontSize="22" FontWeight="Medium"
                                       Margin="4,6"/>
                            <Button Grid.Column="1"
                                    FontFamily="{StaticResource SymbolThemeFontFamily}" 
                                    Content="&#xE710;" HorizontalAlignment="Right"
                                    Command="{Binding Project.CreateLanguageCommand}"
                                    ToolTip="Добавить язык"/>
                        </Grid>
                        <ListView Grid.Row="1" 
                                  ItemsSource="{Binding Languages}">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <lib:LanguageView Margin="0,6,0,10"
                                                      LanguageId="{Binding Id}"
                                                      LanguageName="{Binding Name}"
                                                      ContextMenu="{Binding ContextMenu}"
                                                      IdEditCommand="{Binding EditIdCommand}"
                                                      IdEditCommandParameter="{Binding}"
                                                      NameEditCommand="{Binding EditNameCommand}"
                                                      NameEditCommandParameter="{Binding}"/>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Grid>
            </TabItem>
        </TabControl>
        <GridSplitter Grid.RowSpan="2" Grid.Column="1"/>
        <lib:NodeSelector x:Name="_nodeSelector" Panel.ZIndex="100" 
                          Grid.ColumnSpan="100" Grid.RowSpan="100" 
                          HorizontalAlignment="Left" VerticalAlignment="Top" 
                          MinWidth="200" MaxHeight="300" Visibility="Collapsed"
                          IsHitTestVisible="False"
                          lib2:FocusHelper.IgnoreFocusHit="True"/>
    </Grid>
</Window>
