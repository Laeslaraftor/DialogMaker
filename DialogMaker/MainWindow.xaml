<Window x:Class="DialogMaker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:lib="clr-namespace:DialogMaker.Lib.Elements"
        xmlns:models="clr-namespace:DialogMaker.ViewModels"
        xmlns:local="clr-namespace:DialogMaker"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="1000"
        MinWidth="1000" MinHeight="400">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition MinWidth="200" MaxWidth="400" Width="0.4*"/>
            <ColumnDefinition/>
            <ColumnDefinition MinWidth="400" MaxWidth="500" Width="0.4*"/>
        </Grid.ColumnDefinitions>
        <Menu Grid.ColumnSpan="3">
            <MenuItem Header="Файл">
                <MenuItem Header="Создать"
                          Command="{Binding CreateProjectCommand}"/>
                <MenuItem Header="Открыть"
                          Command="{Binding OpenProjectCommand}"/>
                <MenuItem Header="Сохранить"
                          Command="{Binding Project.SaveCommand}"/>
                <Separator/>
                <MenuItem Header="Закрыть"
                          Command="{Binding CloseProjectCommand}"/>
            </MenuItem>
        </Menu>
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <StackPanel Orientation="Vertical">
                <Button Content="Создать набор"
                        Command="{Binding CreatePackCommand}"
                        IsEnabled="{Binding CanCreatePack}"/>
            </StackPanel>
            <TreeView x:Name="_projectStruct" Grid.Row="1" 
                      ItemsSource="{Binding Project.Packs}">
                <TreeView.ItemTemplate>
                    <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                        <lib:ProjectItemView ContextMenu="{Binding ContextMenu}"
                                             Icon="{Binding Icon}"
                                             ItemName="{Binding Name, Mode=TwoWay}"/>
                    </HierarchicalDataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>
        </Grid>
        <TabControl Grid.Row="1" Grid.Column="2">
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Глобальные ресурсы" />
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <lib:MinimizableView Margin="0,8,0,0">
                            <lib:MinimizableView.Header>
                                <Grid Margin="6,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Строки" FontSize="28"
                                               FontWeight="Medium" Margin="0,0,0,8"/>
                                    <Button Content="Создать" Grid.Column="1" VerticalAlignment="Center"
                                            Command="{Binding GlobalResources.CreateStringCommand}"/>
                                </Grid>
                            </lib:MinimizableView.Header>
                            <lib:MinimizableView.Child>
                                <ListView Grid.Row="1"
                                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                          HorizontalContentAlignment="Stretch"
                                          ItemsSource="{Binding GlobalResources.Strings}">
                                    <ListView.Template>
                                        <ControlTemplate>
                                            <ItemsPresenter/>
                                        </ControlTemplate>
                                    </ListView.Template>
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <lib:ReplicaView ProjectString="{Binding}"
                                                             IsMinimized="{Binding IsMinimized}"
                                                             ContextMenu="{Binding ContextMenu}"/>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </lib:MinimizableView.Child>
                        </lib:MinimizableView>
                        <lib:MinimizableView Margin="0,8,0,0">
                            <lib:MinimizableView.Header>
                                <Grid Margin="6,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Персонажи" FontSize="28"
                                               FontWeight="Medium" Margin="0,0,0,8"/>
                                    <Button Content="Создать" Grid.Column="1" VerticalAlignment="Center"
                                            Command="{Binding GlobalResources.CreateCharacterCommand}"/>
                                </Grid>
                            </lib:MinimizableView.Header>
                            <lib:MinimizableView.Child>
                                <ListView Grid.Row="1"
                                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                          HorizontalContentAlignment="Stretch"
                                          ItemsSource="{Binding GlobalResources.Characters}">
                                    <ListView.Template>
                                        <ControlTemplate>
                                            <ItemsPresenter/>
                                        </ControlTemplate>
                                    </ListView.Template>
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <lib:CharacterView Character="{Binding}"/>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </lib:MinimizableView.Child>
                        </lib:MinimizableView>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            <TabItem IsSelected="True">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Языки" />
                    </StackPanel>
                </TabItem.Header>
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <StackPanel Visibility="{Binding DefaultLanguageVisibility}">
                        <TextBlock Text="Язык по умолчанию"
                                   FontSize="22" FontWeight="Medium"
                                   Margin="4,8"/>
                        <Border Background="{DynamicResource AccentFillColorDefaultBrush}"
                                Padding="16,0" CornerRadius="4">
                            <lib:LanguageView Margin="0,6,0,10"
                                              Foreground="{DynamicResource TextOnAccentFillColorPrimaryBrush}"
                                              LanguageId="{Binding Project.DefaultLanguage.Id}"
                                              LanguageName="{Binding Project.DefaultLanguage.Name}"
                                              ContextMenu="{Binding Project.DefaultLanguage.ContextMenu}"
                                              IdEditCommand="{Binding Project.DefaultLanguage.EditIdCommand}"
                                              IdEditCommandParameter="{Binding Project.DefaultLanguage}"
                                              NameEditCommand="{Binding Project.DefaultLanguage.EditNameCommand}"
                                              NameEditCommandParameter="{Binding Project.DefaultLanguage}"/>
                        </Border>
                    </StackPanel>
                    <Grid Grid.Row="1" Margin="0,6,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Все языки"
                                       FontSize="22" FontWeight="Medium"
                                       Margin="4,6"/>
                            <Button Grid.Column="1"
                                    FontFamily="{StaticResource SymbolThemeFontFamily}" 
                                    Content="&#xE710;" HorizontalAlignment="Right"
                                    Command="{Binding Project.CreateLanguageCommand}"
                                    ToolTip="Добавить язык"/>
                        </Grid>
                        <ListView Grid.Row="1" 
                                  ItemsSource="{Binding Languages}">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <lib:LanguageView Margin="0,6,0,10"
                                                      LanguageId="{Binding Id}"
                                                      LanguageName="{Binding Name}"
                                                      ContextMenu="{Binding ContextMenu}"
                                                      IdEditCommand="{Binding EditIdCommand}"
                                                      IdEditCommandParameter="{Binding}"
                                                      NameEditCommand="{Binding EditNameCommand}"
                                                      NameEditCommandParameter="{Binding}"/>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Grid>
            </TabItem>
        </TabControl>
        <lib:DiagramView Grid.Column="1" Grid.Row="1" ClipToBounds="True"
                         CurvesThickness="6" CurvesOffset="5" CurvesResolution="24"
                         Dialog="{Binding Source={x:Reference Name=_projectStruct}, Path=SelectedItem}"/>
    </Grid>
</Window>
