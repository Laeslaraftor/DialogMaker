<Window x:Class="DialogMaker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:lib="clr-namespace:DialogMaker.Lib.Elements"
        xmlns:local="clr-namespace:DialogMaker"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <lib:DiagramView>
            <lib:DiagramView.Children>
                <Border Width="150" Height="150" Background="Black"
        CornerRadius="8"/>
                <Border Width="150" Height="150" Background="DarkBlue"
        CornerRadius="8"/>
            </lib:DiagramView.Children>
        </lib:DiagramView>
    </Grid>
</Window>
