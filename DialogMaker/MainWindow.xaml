<Window x:Class="DialogMaker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:lib="clr-namespace:DialogMaker.Lib.Elements"
        xmlns:models="clr-namespace:DialogMaker.ViewModels"
        xmlns:local="clr-namespace:DialogMaker"
        xmlns:editor="clr-namespace:DialogMaker.Editor"
        mc:Ignorable="d"
        Title="DialogMaker" Height="450" Width="1000"
        MinWidth="1000" MinHeight="400">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition MinWidth="200" MaxWidth="400" Width="0.4*"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Menu Grid.ColumnSpan="3">
            <MenuItem Header="Файл">
                <MenuItem Header="Создать"
                          Command="{Binding CreateProjectCommand}"/>
                <MenuItem Header="Открыть"
                          Command="{Binding OpenProjectCommand}"/>
                <MenuItem Header="Сохранить"
                          Command="{Binding Project.SaveCommand}"/>
                <Separator/>
                <MenuItem Header="Закрыть"
                          Command="{Binding CloseProjectCommand}"/>
            </MenuItem>
        </Menu>
        <TabControl Grid.Row="1">
            <TabItem IsSelected="True">
                <TabItem.Header>
                    <TextBlock Text="Структура" />
                </TabItem.Header>
                <Grid Margin="4,10,4,4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding Project.Name}"
                                   FontSize="22" FontWeight="Medium"
                                   Margin="4,6"/>
                        <Button Grid.Column="1"
                                FontFamily="{StaticResource SymbolThemeFontFamily}" 
                                Content="&#xE710;" HorizontalAlignment="Right"
                                Command="{Binding CreatePackCommand}"
                                IsEnabled="{Binding CanCreatePack}"
                                ToolTip="Добавить язык"/>
                    </Grid>
                    <TreeView x:Name="_projectStruct" Grid.Row="1" 
                              ItemsSource="{Binding Project.Packs}">
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                <lib:ProjectItemView ContextMenu="{Binding ContextMenu}"
                                                     Icon="{Binding Icon}"
                                                     ItemName="{Binding Name, Mode=TwoWay}"/>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </Grid>
            </TabItem>
            <TabItem>
                <TabItem.Header>
                    <TextBlock Text="Языки" />
                </TabItem.Header>
                <Grid Margin="4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <StackPanel Visibility="{Binding DefaultLanguageVisibility}">
                        <TextBlock Text="Язык по умолчанию"
                                   FontSize="22" FontWeight="Medium"
                                   Margin="4,8"/>
                        <Border Background="{DynamicResource AccentFillColorDefaultBrush}"
                                Padding="16,0" CornerRadius="4">
                            <lib:LanguageView Margin="0,6,0,10"
                                              Foreground="{DynamicResource TextOnAccentFillColorPrimaryBrush}"
                                              LanguageId="{Binding Project.DefaultLanguage.Id}"
                                              LanguageName="{Binding Project.DefaultLanguage.Name}"
                                              ContextMenu="{Binding Project.DefaultLanguage.ContextMenu}"
                                              IdEditCommand="{Binding Project.DefaultLanguage.EditIdCommand}"
                                              IdEditCommandParameter="{Binding Project.DefaultLanguage}"
                                              NameEditCommand="{Binding Project.DefaultLanguage.EditNameCommand}"
                                              NameEditCommandParameter="{Binding Project.DefaultLanguage}"/>
                        </Border>
                    </StackPanel>
                    <Grid Grid.Row="1" Margin="0,6,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Все языки"
                                       FontSize="22" FontWeight="Medium"
                                       Margin="4,6"/>
                            <Button Grid.Column="1"
                                    FontFamily="{StaticResource SymbolThemeFontFamily}" 
                                    Content="&#xE710;" HorizontalAlignment="Right"
                                    Command="{Binding Project.CreateLanguageCommand}"
                                    ToolTip="Добавить язык"/>
                        </Grid>
                        <ListView Grid.Row="1" 
                                  ItemsSource="{Binding Languages}">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <lib:LanguageView Margin="0,6,0,10"
                                                      LanguageId="{Binding Id}"
                                                      LanguageName="{Binding Name}"
                                                      ContextMenu="{Binding ContextMenu}"
                                                      IdEditCommand="{Binding EditIdCommand}"
                                                      IdEditCommandParameter="{Binding}"
                                                      NameEditCommand="{Binding EditNameCommand}"
                                                      NameEditCommandParameter="{Binding}"/>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Grid>
            </TabItem>
        </TabControl>
        <Grid Grid.Row="1" Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition Height="400"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition MinWidth="400" MaxWidth="500" Width="0.4*"/>
            </Grid.ColumnDefinitions>
            <ScrollViewer Grid.RowSpan="2" Grid.Column="1"
                          HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto"
                          Margin="4,0">
                <StackPanel>
                    <lib:MinimizableView Margin="0,8,0,0">
                        <lib:MinimizableView.Header>
                            <Grid Margin="6,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Строки" FontSize="28"
                                               FontWeight="Medium" Margin="0,0,0,8"/>
                                <Button Content="Создать" Grid.Column="1" VerticalAlignment="Center"
                                            Command="{Binding GlobalResources.CreateStringCommand}"/>
                            </Grid>
                        </lib:MinimizableView.Header>
                        <lib:MinimizableView.Child>
                            <ListView Grid.Row="1"
                                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                          HorizontalContentAlignment="Stretch"
                                          ItemsSource="{Binding GlobalResources.Strings}">
                                <ListView.Template>
                                    <ControlTemplate>
                                        <ItemsPresenter/>
                                    </ControlTemplate>
                                </ListView.Template>
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <lib:ReplicaView ProjectString="{Binding}"
                                                             IsMinimized="{Binding IsMinimized}"
                                                             ContextMenu="{Binding ContextMenu}"/>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </lib:MinimizableView.Child>
                    </lib:MinimizableView>
                    <lib:MinimizableView Margin="0,8,0,0">
                        <lib:MinimizableView.Header>
                            <Grid Margin="6,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Персонажи" FontSize="28"
                                               FontWeight="Medium" Margin="0,0,0,8"/>
                                <Button Content="Создать" Grid.Column="1" VerticalAlignment="Center"
                                            Command="{Binding GlobalResources.CreateCharacterCommand}"/>
                            </Grid>
                        </lib:MinimizableView.Header>
                        <lib:MinimizableView.Child>
                            <ListView Grid.Row="1"
                                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                          HorizontalContentAlignment="Stretch"
                                          ItemsSource="{Binding GlobalResources.Characters}">
                                <ListView.Template>
                                    <ControlTemplate>
                                        <ItemsPresenter/>
                                    </ControlTemplate>
                                </ListView.Template>
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <lib:CharacterView Character="{Binding}"/>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </lib:MinimizableView.Child>
                    </lib:MinimizableView>
                    <lib:MinimizableView Margin="0,8,0,0">
                        <lib:MinimizableView.Header>
                            <Grid Margin="6,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Переменные" FontSize="28"
                                               FontWeight="Medium" Margin="0,0,0,8"/>
                                <lib:DropDownButton Text="Создать" Grid.Column="1" VerticalAlignment="Center"
                                                        ContextMenu="{Binding GlobalResources.CreateVariablesContextMenu}"/>
                            </Grid>
                        </lib:MinimizableView.Header>
                        <lib:MinimizableView.Child>
                            <ListView Grid.Row="1"
                                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                          HorizontalContentAlignment="Stretch"
                                          ItemsSource="{Binding GlobalResources.Variables}">
                                <ListView.Template>
                                    <ControlTemplate>
                                        <ItemsPresenter/>
                                    </ControlTemplate>
                                </ListView.Template>
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <lib:VariableView Variable="{Binding}"/>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </lib:MinimizableView.Child>
                    </lib:MinimizableView>
                </StackPanel>
            </ScrollViewer>
            <lib:DiagramView ClipToBounds="True"
                             CurvesThickness="6" CurvesOffset="5" CurvesResolution="24"
                             Dialog="{Binding Source={x:Reference Name=_projectStruct}, Path=SelectedItem}"/>
            <Border Grid.RowSpan="2"
                    BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}"
                    BorderThickness="1,0,1,0"/>
            <Border Grid.Row="1" VerticalAlignment="Top"
                    Background="{DynamicResource DividerStrokeColorDefaultBrush}"
                    Height="1"/>
            <Grid Grid.Row="1" Margin="8,2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Файлы" FontSize="28"
                               FontWeight="Medium" Margin="0,0,0,8"/>
                    <lib:Entry MaxWidth="300" Grid.Column="1" Placeholder="Поиск..."
                               VerticalAlignment="Center" Margin="5,0"/>
                    <Button Content="Добавить" Grid.Column="2" VerticalAlignment="Center"
                            Command="{Binding GlobalResources.AddFileCommand}"
                            HorizontalAlignment="Right"/>
                </Grid>
                <ListView Grid.Row="1" SelectionMode="Single"
                          ItemsSource="{Binding GlobalResources.Files}">
                    <ListView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ListView.ItemsPanel>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <lib:FileView File="{Binding}"/>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Grid>
    </Grid>
</Window>
