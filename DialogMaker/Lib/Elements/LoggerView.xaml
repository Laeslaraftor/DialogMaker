<UserControl x:Class="DialogMaker.Lib.Elements.LoggerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DialogMaker.Lib.Elements"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>
        <StackPanel x:Name="_previewMessagesContainer" Width="400"
                    VerticalAlignment="Bottom" HorizontalAlignment="Left"
                    Margin="12,0,0,12"/>
        <Border x:Name="_messagesWindow" BorderThickness="1"
                Visibility="Collapsed"
                Background="{DynamicResource SolidBackgroundFillColorSecondaryBrush}"
                BorderBrush="{DynamicResource SurfaceStrokeColorDefaultBrush}"
                VerticalAlignment="Bottom" HorizontalAlignment="Left"
                Width="500" Height="400" CornerRadius="4" Margin="12,0,0,12">
            <Border.Effect>
                <DropShadowEffect BlurRadius="50" ShadowDepth="0"
                                  Opacity="0.25"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="40"/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <TextBlock Text="Уведомления" FontSize="20" FontWeight="Medium"
                           VerticalAlignment="Center" Margin="12,6,6,6"/>
                <Button FontFamily="{StaticResource SymbolThemeFontFamily}"
                        VerticalAlignment="Center" HorizontalAlignment="Right"
                        Content="&#xE74D;" Padding="6" Margin="6"
                        ToolTip="Удалить все уведомления" Click="OnClearButtonClicked"/>
                <Border VerticalAlignment="Bottom" Height="1"
                        Background="{DynamicResource DividerStrokeColorDefaultBrush}"/>
                <ScrollViewer x:Name="_messagesScroll" Grid.Row="1"
                              HorizontalScrollBarVisibility="Disabled">
                    <ListView x:Name="_messagesList" 
                              Style="{StaticResource NoSelectionListView}">
                        <ListView.Template>
                            <ControlTemplate>
                                <ItemsPresenter/>
                            </ControlTemplate>
                        </ListView.Template>
                        <ListView.ItemsPanel>
                            <ItemsPanelTemplate>
                                <VirtualizingStackPanel Margin="0,0,0,8"/>
                            </ItemsPanelTemplate>
                        </ListView.ItemsPanel>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <local:MessageView Message="{Binding}" Margin="8,8,8,0"
                                                   RemoveRequested="OnMessageViewRemoveRequested"/>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </ScrollViewer>
            </Grid>
        </Border>
        <Grid Grid.Row="1">
            <Border Background="{DynamicResource TextOnAccentFillColorPrimaryBrush}"
                    Opacity="0.25"/>
            <StackPanel Orientation="Horizontal">
                <Border Width="30">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#1AFFFFFF"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="False">
                                    <Setter Property="Background" Value="Transparent"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid>
                        <TextBlock Text="&#xEA8F;" 
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"
                                   FontFamily="{StaticResource SymbolThemeFontFamily}"/>
                        <Border x:Name="_unreadCounter" Visibility="Collapsed"
                                MinWidth="12" Height="12" CornerRadius="6" Padding="2,0"
                                HorizontalAlignment="Right" VerticalAlignment="Top"
                                Background="{DynamicResource SystemFillColorCriticalBrush}">
                            <TextBlock x:Name="_unreadCounterText" FontSize="10"
                                       VerticalAlignment="Center" HorizontalAlignment="Center"
                                       Foreground="{DynamicResource TextOnAccentFillColorPrimaryBrush}"/>
                        </Border>
                        <Button Padding="0" Opacity="0"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                PreviewMouseDown="OnShowMessagesWindowButtonClicked"/>
                    </Grid>
                </Border>
                <TextBlock x:Name="_lastMessageText" Margin="2,0,0,0"
                           Visibility="Collapsed"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
