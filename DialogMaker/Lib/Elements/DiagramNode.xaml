<UserControl x:Class="DialogMaker.Lib.Elements.DiagramNode"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DialogMaker.Lib.Elements"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Border x:Name="_main"
            Background="{DynamicResource SolidBackgroundFillColorBaseBrush}"
            BorderBrush="{DynamicResource SurfaceStrokeColorDefaultBrush}" 
            BorderThickness="1" CornerRadius="8">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="5"/>
            </Grid.RowDefinitions>
            <TextBlock x:Name="_title" Grid.ColumnSpan="3" 
                       Margin="12,4" FontWeight="Medium"/>
            <Border VerticalAlignment="Bottom" Grid.ColumnSpan="3"
                    Background="{DynamicResource SurfaceStrokeColorDefaultBrush}"
                    Height="1"/>
            <StackPanel x:Name="_inputs" Grid.Row="1" 
                        Margin="4" Orientation="Vertical"/>
            <StackPanel x:Name="_outputs" Grid.Row="1" Margin="4"
                        Grid.Column="2" Orientation="Vertical"/>
            <StackPanel x:Name="_properties" Grid.Row="1" 
                        Grid.Column="1" Margin="4" MaxWidth="300"/>
            <Border x:Name="_selectionOutline" Visibility="Collapsed"
                    Grid.ColumnSpan="3" Grid.RowSpan="3"
                    CornerRadius="10" Margin="-4"
                    BorderBrush="{DynamicResource FocusStrokeColorOuterBrush}"
                    BorderThickness="2">
                <Border BorderBrush="{DynamicResource FocusStrokeColorInnerBrush}"
                        BorderThickness="2" CornerRadius="9"/>
            </Border>
        </Grid>
    </Border>
</UserControl>
