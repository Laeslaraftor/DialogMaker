<UserControl x:Class="DialogMaker.Lib.Elements.DiagramNode"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DialogMaker.Lib.Elements"
             xmlns:converters="clr-namespace:DialogMaker.Lib.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <converters:MessageTypeConverter x:Key="_messageTypeConverter"/>
    </UserControl.Resources>
    <Border x:Name="_main"
            Background="{DynamicResource SolidBackgroundFillColorBaseBrush}"
            BorderBrush="{DynamicResource SurfaceStrokeColorDefaultBrush}" 
            BorderThickness="1" CornerRadius="8">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="5"/>
            </Grid.RowDefinitions>
            <Grid Grid.ColumnSpan="3" Margin="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="_title" FontWeight="Medium"
                           VerticalAlignment="Center" FontSize="18"
                           Margin="4,0"/>
                <Button Grid.Column="1" Content="&#xE8AB;"
                        FontFamily="{StaticResource SymbolThemeFontFamily}"
                        ToolTip="Сменить направление"
                        Click="OnInvertButtonClicked"
                        VerticalAlignment="Center"/>
            </Grid>
            <Border VerticalAlignment="Bottom" Grid.ColumnSpan="3"
                    Background="{DynamicResource SurfaceStrokeColorDefaultBrush}"
                    Height="1"/>
            <ListView x:Name="_messagesList" 
                      Background="Black"
                      Grid.Row="1" Grid.ColumnSpan="3"
                      HorizontalAlignment="Center"
                      Style="{StaticResource NoSelectionListView}"
                      MaxWidth="350" Margin="4,0">
                <ListView.Template>
                    <ControlTemplate>
                        <ItemsPresenter/>
                    </ControlTemplate>
                </ListView.Template>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <local:ToolTipView Text="{Binding Text}"
                                           MessageType="{Binding Path=Importance, Converter={StaticResource _messageTypeConverter}}"
                                           Commands="{Binding Commands}"
                                           Margin="0,4,0,0"/>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
            <StackPanel x:Name="_inputs" Grid.Row="2"
                        Margin="-4,0,4,0" Orientation="Vertical"/>
            <StackPanel x:Name="_outputs" Grid.Row="2" Margin="4,0,-4,0"
                        Grid.Column="2" Orientation="Vertical"/>
            <StackPanel x:Name="_properties" Grid.Row="2" 
                        Grid.Column="1" Margin="4" MaxWidth="300"/>
            <Border x:Name="_selectionOutline" Visibility="Collapsed"
                    Grid.ColumnSpan="3" Grid.RowSpan="4"
                    CornerRadius="10" Margin="-4"
                    BorderBrush="{DynamicResource FocusStrokeColorOuterBrush}"
                    BorderThickness="2" Panel.ZIndex="-1">
                <Border BorderBrush="{DynamicResource FocusStrokeColorInnerBrush}"
                        BorderThickness="2" CornerRadius="9"/>
            </Border>
        </Grid>
    </Border>
</UserControl>
