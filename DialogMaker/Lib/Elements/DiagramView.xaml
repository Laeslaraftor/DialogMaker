<UserControl x:Class="DialogMaker.Lib.Elements.DiagramView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DialogMaker.Lib.Elements"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid x:Name="_mainGrid" Background="Transparent">
        <Canvas x:Name="_canvas"
                RenderTransformOrigin="0.5,0.5"
                MaxWidth="200" MaxHeight="200"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"/>
        <local:NodeSelector x:Name="_nodeSelector" Panel.ZIndex="100" 
                            Grid.ColumnSpan="100" Grid.RowSpan="100" 
                            HorizontalAlignment="Left" VerticalAlignment="Top" 
                            MinWidth="200" MaxHeight="300" Visibility="Collapsed"
                            IsHitTestVisible="False"
                            NodeSelected="OnNodeSelectorNodeSelected"
                            LostFocus="OnNodeSelectorLostFocus"/>
    </Grid>
</UserControl>
