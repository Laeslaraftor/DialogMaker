<UserControl x:Class="DialogMaker.Lib.Elements.DiagramStructureItemView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DialogMaker.Lib.Elements"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Border Background="{DynamicResource AccentFillColorSelectedTextBackgroundBrush}"
            Padding="2" CornerRadius="10">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <ListView x:Name="_dataList"
                      HorizontalAlignment="Left"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                      ScrollViewer.VerticalScrollBarVisibility="Disabled"
                      Style="{StaticResource NoSelectionListView}">
                <ListView.Template>
                    <ControlTemplate>
                        <ItemsPresenter/>
                    </ControlTemplate>
                </ListView.Template>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <local:SimpleNode Title="{Binding Name}"
                                          Preview="{Binding Original}"
                                          MaxWidth="150" FontSize="12"/>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
            <local:SimpleNode x:Name="_node" Grid.Column="1"
                              Title="{Binding Name}"
                              Preview="{Binding Original}"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              MaxWidth="300" Margin="5,0,0,0"
                              FontSize="12"/>
        </Grid>
    </Border>
</UserControl>
