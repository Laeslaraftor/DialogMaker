<UserControl x:Class="DialogMaker.Lib.Elements.SimpleNode"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DialogMaker.Lib.Elements"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Border x:Name="_main"
            Background="{DynamicResource SolidBackgroundFillColorBaseBrush}"
            BorderBrush="{DynamicResource SurfaceStrokeColorDefaultBrush}" 
            BorderThickness="1" CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="5"/>
            </Grid.RowDefinitions>
            <TextBlock x:Name="_title" Margin="12,4" FontWeight="Medium"/>
            <Border VerticalAlignment="Bottom" Height="1"
                    Background="{DynamicResource SurfaceStrokeColorDefaultBrush}"/>
            <Label x:Name="_content" Padding="12,2"
                   Grid.Row="1"/>
            <Border x:Name="_selectionOutline" Visibility="Collapsed"
                    Grid.RowSpan="3" CornerRadius="10" Margin="-4"
                    BorderBrush="{DynamicResource FocusStrokeColorOuterBrush}"
                    BorderThickness="2">
                <Border BorderBrush="{DynamicResource FocusStrokeColorInnerBrush}"
                        BorderThickness="2" CornerRadius="9"/>
            </Border>
        </Grid>
    </Border>
</UserControl>
