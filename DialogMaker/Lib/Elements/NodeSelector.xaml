<UserControl x:Class="DialogMaker.Lib.Elements.NodeSelector"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DialogMaker.Lib.Elements"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Border Background="{DynamicResource SolidBackgroundFillColorSecondaryBrush}" 
            BorderBrush="{DynamicResource SurfaceStrokeColorDefaultBrush}"
            Padding="4" CornerRadius="4" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="50" Opacity="0.25"
                              ShadowDepth="0"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <local:Entry x:Name="_searchValueEntry" Placeholder="Поиск..." 
                         TextBoxMinHeight="0" TextBoxPadding="8,4,0,2"
                         Height="25" FontSize="12" Margin="0,0,0,4"
                         TextChanged="OnEntryTextChanged"/>
            <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                          Grid.Row="1">
                <ListView x:Name="_groupsList"
                          Style="{StaticResource NoSelectionListView}"
                          ScrollViewer.VerticalScrollBarVisibility="Disabled">
                    <ListView.Template>
                        <ControlTemplate>
                            <ItemsPresenter/>
                        </ControlTemplate>
                    </ListView.Template>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <local:NodeSelectorGroup RootItem="{Binding}"
                                                     ItemSelected="OnNodeSelectorGroupItemSelected">
                                <local:NodeSelectorGroup.Style>
                                    <Style TargetType="local:NodeSelectorGroup">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsEnabled}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </local:NodeSelectorGroup.Style>
                            </local:NodeSelectorGroup>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </ScrollViewer>
        </Grid>
    </Border>
</UserControl>
