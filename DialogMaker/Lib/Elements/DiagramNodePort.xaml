<UserControl x:Class="DialogMaker.Lib.Elements.DiagramNodePort"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DialogMaker.Lib.Elements"
             mc:Ignorable="d" HorizontalAlignment="Stretch"
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin="0,4,0,0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="_firstColumn"/>
            <ColumnDefinition x:Name="_secondColumn"
                              Width="Auto"/>
        </Grid.ColumnDefinitions>
        <Border x:Name="_mainContainer"
                Background="{DynamicResource ControlStrokeColorDefaultBrush}"
                CornerRadius="4" Margin="0,0,-6,0">
            <Grid>
                <Border x:Name="_mainContainerBorder"
                        BorderBrush="{DynamicResource AccentFillColorDefaultBrush}"
                        BorderThickness="2,0.5,0.5,0.5" CornerRadius="4"
                        RenderTransformOrigin="0.5,0.5">
                    <Border.RenderTransform>
                        <ScaleTransform x:Name="_mainContainerBorderScale" ScaleX="-1"/>
                    </Border.RenderTransform>
                    <Border.OpacityMask>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="Black" Offset="0"/>
                            <GradientStop Color="Transparent" Offset="0.75"/>
                        </LinearGradientBrush>
                    </Border.OpacityMask>
                </Border>
                <Grid Margin="8,4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <ContentPresenter x:Name="_fieldContainer" Margin="0,2"
                                      Grid.Row="1" MaxWidth="250"/>
                    <TextBlock x:Name="_text"/>
                </Grid>
            </Grid>
        </Border>
        <Border x:Name="_border" Grid.Column="1" Width="14" Height="14"
                    BorderBrush="{DynamicResource AccentFillColorDefaultBrush}" 
                    BorderThickness="2" CornerRadius="30"
                    RenderTransformOrigin="0.5,0.5">
            <Border.RenderTransform>
                <TranslateTransform x:Name="_borderOffset" X="12"/>
            </Border.RenderTransform>
            <Grid>
                <Border x:Name="_background" Background="{DynamicResource AccentFillColorDefaultBrush}"
                        Opacity="0.1" CornerRadius="30"/>
                <Border x:Name="_borderFade" Background="{DynamicResource AccentFillColorDefaultBrush}"
                        VerticalAlignment="Center" Width="8" Height="40"
                        RenderTransformOrigin="0.5,0.5">
                    <Border.RenderTransform>
                        <TransformGroup>
                            <TranslateTransform X="10"/>
                            <ScaleTransform x:Name="_borderFadeScale" ScaleX="-1" ScaleY="1.5"/>
                        </TransformGroup>
                    </Border.RenderTransform>
                    <Border.Clip>
                        <CombinedGeometry GeometryCombineMode="Exclude">
                            <CombinedGeometry.Geometry1>
                                <RectangleGeometry Rect="0,0,8,40"/>
                            </CombinedGeometry.Geometry1>
                            <CombinedGeometry.Geometry2>
                                <CombinedGeometry GeometryCombineMode="Union">
                                    <CombinedGeometry.Geometry1>
                                        <RectangleGeometry Rect="-4,6,12,12" RadiusX="4" RadiusY="4"/>
                                    </CombinedGeometry.Geometry1>
                                    <CombinedGeometry.Geometry2>
                                        <RectangleGeometry Rect="-4,22,12,12" RadiusX="4" RadiusY="4"/>
                                    </CombinedGeometry.Geometry2>
                                </CombinedGeometry>
                            </CombinedGeometry.Geometry2>
                        </CombinedGeometry>
                    </Border.Clip>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
