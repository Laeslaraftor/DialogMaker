<UserControl x:Class="DialogMaker.Lib.Elements.DialogValueTypeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DialogMaker.Lib.Elements"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Border Background="{DynamicResource AccentFillColorDefaultBrush}"
            CornerRadius="4" Padding="6,2">
        <TextBlock x:Name="_typeName" FontWeight="Medium"
                   Foreground="{DynamicResource TextOnAccentFillColorPrimaryBrush}"/>
    </Border>
</UserControl>
