<UserControl x:Class="DialogMaker.Lib.Elements.ColorPickerSelectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DialogMaker.Lib.Elements"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition/>
            <RowDefinition Height="40"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition Width="40"/>
        </Grid.ColumnDefinitions>
        <Border Grid.ColumnSpan="2" Margin="10,8,10,0"
                CornerRadius="4">
            <Border.Background>
                <ImageBrush ImageSource="/Lib/Images/EmptyBackgroundPlaceholder.jpg"
                            Stretch="UniformToFill"/>
            </Border.Background>
            <Border CornerRadius="4">
                <Border.Background>
                    <SolidColorBrush x:Name="_preview" Color="White"/>
                </Border.Background>
            </Border>
        </Border>
        <Grid x:Name="_colorSlider" Grid.Row="1" Margin="10,6,10,0">
            <local:ClippingBorder CornerRadius="4">
                <Grid>
                    <Canvas>
                        <Canvas.Background>
                            <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                <GradientStop Color="White" Offset="0"/>
                                <GradientStop x:Name="_mainColor" Color="Red" Offset="1"/>
                            </LinearGradientBrush>
                        </Canvas.Background>
                    </Canvas>
                    <Canvas>
                        <Canvas.Background>
                            <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                <GradientStop Color="#00000000" Offset="0"/>
                                <GradientStop Color="Black" Offset="1"/>
                            </LinearGradientBrush>
                        </Canvas.Background>
                    </Canvas>
                </Grid>
            </local:ClippingBorder>
            <Border Width="12" Height="12" BorderThickness="1" 
                    CornerRadius="6" BorderBrush="#50000000"
                    HorizontalAlignment="Left" VerticalAlignment="Top"
                    Margin="-6,-6,0,0">
                <Border.RenderTransform>
                    <TranslateTransform x:Name="_colorTransform"/>
                </Border.RenderTransform>
                <Border BorderThickness="2" CornerRadius="5"
                        BorderBrush="White">
                    <Border CornerRadius="3" BorderThickness="1"
                            BorderBrush="Black" Opacity="0.5"/>
                </Border>
            </Border>
        </Grid>
        <Border x:Name="_opacitySlider" Grid.Row="2"
                Margin="10,8" CornerRadius="4">
            <Border.Background>
                <ImageBrush ImageSource="/Lib/Images/EmptyBackgroundPlaceholder.jpg"
                            Stretch="UniformToFill"/>
            </Border.Background>
            <Grid>
                <Border CornerRadius="4">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Offset="0" Color="#00000000"/>
                            <GradientStop x:Name="_tansparentPreview" Offset="1" Color="White"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>
                <Border Width="5" Margin="-2.5,-4,0,-5"
                        HorizontalAlignment="Left"
                        CornerRadius="2.5" Background="White">
                    <Border.RenderTransform>
                        <TranslateTransform x:Name="_opacityTransform"/>
                    </Border.RenderTransform>
                </Border>
            </Grid>
        </Border>
        <Border x:Name="_channelSlider" 
                Grid.Column="1" Grid.Row="1" Grid.RowSpan="2"
                Margin="0,8,10,8" CornerRadius="4">
            <Border.Background>
                <LinearGradientBrush x:Name="_channelsGradient" 
                                     StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Offset="0" Color="#FFFF0000"/>
                    <GradientStop Offset="0.1666666666666667" Color="#FFFFFF00"/>
                    <GradientStop Offset="0.3333333333333334" Color="#FF00FF00"/>
                    <GradientStop Offset="0.5" Color="#FF00FFFF"/>
                    <GradientStop Offset="0.6666666666666668" Color="#FF0000FF"/>
                    <GradientStop Offset="0.8333333333333335" Color="#FFFF00FF"/>
                    <GradientStop Offset="1" Color="#FFFF0000"/>
                </LinearGradientBrush>
            </Border.Background>
            <Border Height="5" 
                    Margin="-4,-2.5,-5,0" VerticalAlignment="Top"
                    CornerRadius="2.5" Background="White">
                <Border.RenderTransform>
                    <TranslateTransform x:Name="_channelTransform"/>
                </Border.RenderTransform>
            </Border>
        </Border>
        <local:Entry x:Name="_hexColor" Margin="10,0,10,6"
                     Grid.Row="3" Grid.ColumnSpan="2" 
                     Placeholder="HEX" ConfirmedText="OnHexColorConfirmedText"/>
    </Grid>
</UserControl>
