<UserControl x:Class="DialogMaker.Lib.Elements.FaceEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DialogMaker.Lib.Elements"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition MinWidth="300"/>
        </Grid.ColumnDefinitions>
        <local:FaceView x:Name="_faceView" 
                        RenderTransformOrigin="0.5,0.5"
                        LeftEyebrowVerticalPosition="{Binding LeftEye.Eyebrow.YPosition}"
                        LeftEyebrowRotation="{Binding LeftEye.Eyebrow.ZRotation}"
                        LeftEyeClosedValue="{Binding LeftEye.ClosePercent}"
                        RightEyebrowVerticalPosition="{Binding RightEye.Eyebrow.YPosition}"
                        RightEyebrowRotation="{Binding RightEye.Eyebrow.ZRotation}"
                        RightEyeClosedValue="{Binding RightEye.ClosePercent}"
                        MouthOpenedValue="{Binding Mouth.OpenPercent}"
                        MouthHorizontalStretch="{Binding Mouth.HorizontalStretchPercent}"
                        LeftMouthCornerVerticalPosition="{Binding Mouth.LeftCornerYPosition}"
                        RightMouthCornerVerticalPosition="{Binding Mouth.RightCornerYPosition}">
            <local:FaceView.RenderTransform>
                <ScaleTransform ScaleX="0.8" ScaleY="0.8"/>
            </local:FaceView.RenderTransform>
        </local:FaceView>
        <ScrollViewer Grid.Column="1" Padding="0,6,6,6"
                      HorizontalScrollBarVisibility="Disabled">
            <ListView x:Name="_propertiesList"
                      ScrollViewer.VerticalScrollBarVisibility="Disabled"
                      Style="{StaticResource NoSelectionListView}">
                <ListView.Template>
                    <ControlTemplate>
                        <ItemsPresenter/>
                    </ControlTemplate>
                </ListView.Template>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{DynamicResource LayerOnAcrylicFillColorDefaultBrush}"
                                BorderBrush="{DynamicResource SurfaceStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                Padding="8" Margin="0,4,0,0" CornerRadius="4">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="{Binding Name}" FontSize="16"
                                           FontWeight="Medium" Margin="0,0,0,4"/>
                                <ListView Grid.Row="1" ItemsSource="{Binding Childs}"
                                          ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                          Style="{StaticResource NoSelectionListView}">
                                    <ListView.Template>
                                        <ControlTemplate>
                                            <ItemsPresenter/>
                                        </ControlTemplate>
                                    </ListView.Template>
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{DynamicResource LayerOnAcrylicFillColorDefaultBrush}"
                                                    BorderBrush="{DynamicResource SurfaceStrokeColorDefaultBrush}"
                                                    BorderThickness="1"
                                                    Padding="8" Margin="0,4,0,0" CornerRadius="4">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition/>
                                                    </Grid.RowDefinitions>
                                                    <TextBlock Text="{Binding Name}" FontSize="16"
                                                               FontWeight="Medium" Margin="0,0,0,4"/>
                                                    <ListView Grid.Row="2"
                                                              ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                                              Style="{StaticResource NoSelectionListView}"
                                                              ItemsSource="{Binding Properties}">
                                                        <ListView.Template>
                                                            <ControlTemplate>
                                                                <ItemsPresenter/>
                                                            </ControlTemplate>
                                                        </ListView.Template>
                                                        <ListView.ItemTemplate>
                                                            <DataTemplate>
                                                                <Grid Margin="0,4,0,0">
                                                                    <Grid.RowDefinitions>
                                                                        <RowDefinition Height="Auto"/>
                                                                        <RowDefinition/>
                                                                    </Grid.RowDefinitions>
                                                                    <TextBlock Text="{Binding Name}"/>
                                                                    <ContentPresenter Grid.Row="1" 
                                                                                      Content="{Binding View}"/>
                                                                </Grid>
                                                            </DataTemplate>
                                                        </ListView.ItemTemplate>
                                                    </ListView>
                                                    <ContentPresenter Grid.Row="1" 
                                                                      Content="{Binding View}"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                                <ListView Grid.Row="2"
                                          ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                          Style="{StaticResource NoSelectionListView}"
                                          ItemsSource="{Binding Properties}">
                                    <ListView.Template>
                                        <ControlTemplate>
                                            <ItemsPresenter/>
                                        </ControlTemplate>
                                    </ListView.Template>
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,4,0,0">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition/>
                                                </Grid.RowDefinitions>
                                                <TextBlock Text="{Binding Name}"/>
                                                <ContentPresenter Grid.Row="1" 
                                                                  Content="{Binding View}"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                                <ContentPresenter Grid.Row="1" 
                                              Content="{Binding View}"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </ScrollViewer>
    </Grid>
</UserControl>
