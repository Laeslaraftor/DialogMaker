<ContentControl x:Class="DialogMaker.Lib.Elements.DropDownButton"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DialogMaker.Lib.Elements"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Button Click="OnButtonClick">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="_text" Margin="0,0,6,0"/>
            <Border Background="Gray" Width="1"
                    HorizontalAlignment="Left" Grid.Column="1"/>
            <TextBlock FontFamily="{StaticResource SymbolThemeFontFamily}" 
                       Text="&#xE70D;" Grid.Column="1" FontSize="12"
                       VerticalAlignment="Center" Margin="6,0,0,0"/>
        </Grid>
    </Button>
</ContentControl>
