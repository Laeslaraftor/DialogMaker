<UserControl x:Class="DialogMaker.Lib.Elements.DialogCompilerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DialogMaker.Lib.Elements"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <TabControl>
        <TabItem Header="Предпросмотр">
            <ListView x:Name="_sectionView">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid IsHitTestVisible="False">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>
                            <TextBlock FontSize="18" FontWeight="Medium">
                                <Run Text="Сегмент "/>
                                <Run Text="{Binding Index, Mode=OneWay}"/>
                            </TextBlock>
                            <ListView Grid.Row="1" ItemsSource="{Binding Operations}">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem"/>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Label Content="{Binding}" Padding="0"/>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </TabItem>
        <TabItem Header="Код">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <ListView x:Name="_codeView">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid IsHitTestVisible="False">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition/>
                                </Grid.RowDefinitions>
                                <TextBlock FontSize="18" FontWeight="Medium">
                            <Run Text="Сегмент "/>
                            <Run Text="{Binding Index, Mode=OneWay}"/>
                                </TextBlock>
                                <ListView Grid.Row="1" ItemsSource="{Binding Operations}">
                                    <ListView.ItemContainerStyle>
                                        <Style TargetType="ListViewItem"/>
                                    </ListView.ItemContainerStyle>
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <Label Content="{Binding}" Padding="0"/>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="Ресурсы" FontSize="18"
                               FontWeight="Medium"/>
                    <ListView x:Name="_resourcesList">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition />
                                    </Grid.ColumnDefinitions>
                                    <Label ContentStringFormat="№{0}" Content="{Binding Index, Mode=OneWay}"
                                           FontWeight="Medium" FontSize="16" VerticalAlignment="Center"
                                           Margin="0,0,4,0"/>
                                    <local:EnumValueView Grid.Column="1"
                                                         Value="{Binding Reference.Type}"
                                                         HorizontalAlignment="Left"/>
                                    <Label Grid.Row="1" Grid.ColumnSpan="2"
                                           Content="{Binding ResourceItem}"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Grid>
        </TabItem>
    </TabControl>
</UserControl>
