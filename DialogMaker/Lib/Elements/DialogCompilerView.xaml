<UserControl x:Class="DialogMaker.Lib.Elements.DialogCompilerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DialogMaker.Lib.Elements"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid x:Name="_progressGrid" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <TextBlock Text="Сборка..." FontWeight="Medium"
                       FontSize="20" VerticalAlignment="Bottom"
                       HorizontalAlignment="Center" Margin="0,0,0,8"/>
            <ProgressBar x:Name="_progressBar" Grid.Row="1" 
                         Width="200" IsIndeterminate="True"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Top" Margin="0,8,0,0"/>
        </Grid>
        <local:ToolTipView x:Name="_errorView" MessageType="Error"
                           Visibility="Collapsed"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
        <Grid x:Name="_mainGrid" Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <local:DialogPlayer x:Name="_dialogPlayer"/>
            <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto"
                          Grid.Column="1">
                <ListView x:Name="_codeView"
                          ScrollViewer.VerticalScrollBarVisibility="Disabled">
                    <ListView.Template>
                        <ControlTemplate>
                            <ItemsPresenter/>
                        </ControlTemplate>
                    </ListView.Template>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition/>
                                </Grid.RowDefinitions>
                                <TextBlock FontSize="18" FontWeight="Medium">
                                    <Run Text="Сегмент "/>
                                    <Run Text="{Binding Index, Mode=OneWay}"/>
                                </TextBlock>
                                <ListView Grid.Row="1" ItemsSource="{Binding}"
                                          Style="{StaticResource NoSelectionListView}">
                                    <ListView.Template>
                                        <ControlTemplate>
                                            <ItemsPresenter/>
                                        </ControlTemplate>
                                    </ListView.Template>
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <Grid TextElement.FontFamily="{StaticResource CascadiaMono}"
                                                  TextElement.FontSize="16" Margin="0,2,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Orientation="Horizontal"
                                                            VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Key}"/>
                                                    <TextBlock Text=": "/>
                                                </StackPanel>
                                                <local:OperationView Grid.Column="1" Operation="{Binding Value}"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </ScrollViewer>
            <ListView x:Name="_resourcesList"
                      Grid.Column="2">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{DynamicResource LayerFillColorDefaultBrush}"
                                BorderBrush="{DynamicResource SurfaceStrokeColorDefaultBrush}"
                                CornerRadius="4" BorderThickness="1" Padding="4">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition />
                                </Grid.ColumnDefinitions>
                                <Label ContentStringFormat="№{0}" Content="{Binding Index, Mode=OneWay}"
                                       FontWeight="Medium" FontSize="20" VerticalAlignment="Center"
                                       Grid.RowSpan="2" Margin="0,0,4,0"/>
                                <StackPanel Orientation="Horizontal" Grid.Column="1">
                                    <local:EnumValueView Value="{Binding Reference.Type}"
                                                 HorizontalAlignment="Left"/>
                                </StackPanel>
                                <Label Grid.Row="1" Grid.Column="1"
                                       Content="{Binding ResourceItem}" HorizontalAlignment="Left"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>
    </Grid>
</UserControl>
