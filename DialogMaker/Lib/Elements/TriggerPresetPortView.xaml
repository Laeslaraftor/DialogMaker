<UserControl x:Class="DialogMaker.Lib.Elements.TriggerPresetPortView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DialogMaker.Lib.Elements"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <StackPanel ContextMenu="{Binding ContextMenu}">
        <local:EditableTextBlock Text="{Binding Name, Mode=TwoWay}" 
                                 AutoEdit="True" Margin="0,0,0,6"
                                 FontSize="18"/>
        <local:ObjectValueInput x:Name="_valueInput"
                                AllowedValues="AllWithoutList"
                                SelectedValueType="{Binding ValueType, Mode=TwoWay}"
                                Placeholder="Значение"
                                ValueChanged="OnValueInputValueChanged"/>
    </StackPanel>
</UserControl>
