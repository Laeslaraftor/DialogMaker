<UserControl x:Class="DialogMaker.Lib.Elements.ColorPicker"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DialogMaker.Lib.Elements"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Border x:Name="_main" Cursor="Hand">
        <Border.Clip>
            <RectangleGeometry x:Name="_clipGeometry" Rect="0,0,100,20"/>
        </Border.Clip>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition Height="3"/>
            </Grid.RowDefinitions>
            <Border Grid.RowSpan="2">
                <Border.Background>
                    <SolidColorBrush x:Name="_mainColor"/>
                </Border.Background>
            </Border>
            <Border x:Name="_opacity" Grid.Row="1" HorizontalAlignment="Left"
                    Background="White"/>
            <Button Grid.ColumnSpan="2" Opacity="0"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Click="OnButtonClicked"/>
        </Grid>
    </Border>
</UserControl>
