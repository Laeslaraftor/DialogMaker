<UserControl x:Class="DialogMaker.Lib.Elements.EditableTextBlock"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DialogMaker.Lib.Elements"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <TextBlock x:Name="_block" 
                   MouseDown="OnBlockMouseDown"/>
        <TextBox x:Name="_box" Visibility="Hidden" Margin="-2.9,-1,0,0" 
                 Padding="0" MinHeight="0" 
                 KeyDown="OnBoxKeyDown"/>
    </Grid>
</UserControl>
