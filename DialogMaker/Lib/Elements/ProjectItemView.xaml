<UserControl x:Class="DialogMaker.Lib.Elements.ProjectItemView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DialogMaker.Lib.Elements"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <TextBlock x:Name="_icon" FontSize="14" VerticalAlignment="Center"
                   Margin="0,0,6,0"
                   FontFamily="{StaticResource SymbolThemeFontFamily}" />
        <TextBlock x:Name="_name" Grid.Column="1" FontSize="16"
                   MouseLeftButtonDown="OnNameMouseLeftButtonDown"/>
        <TextBox x:Name="_nameEditor" Grid.Column="1"
                 Visibility="Hidden" Margin="-2.9,-1,0,0" 
                 Padding="0" MinHeight="0" FontSize="16"
                 KeyDown="OnNameEditorKeyDown"/>
    </Grid>
</UserControl>
