<UserControl x:Class="DialogMaker.Lib.Elements.SelectionBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DialogMaker.Lib.Elements"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.RenderTransform>
        <TranslateTransform x:Name="_translation"/>
    </UserControl.RenderTransform>
    <Border BorderBrush="{DynamicResource AccentFillColorDefaultBrush}"
            BorderThickness="1" CornerRadius="2">
        <Border Background="{DynamicResource AccentFillColorDefaultBrush}"
                Opacity="0.25" CornerRadius="2"/>
    </Border>
</UserControl>
