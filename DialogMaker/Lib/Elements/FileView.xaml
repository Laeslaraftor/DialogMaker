<UserControl x:Class="DialogMaker.Lib.Elements.FileView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DialogMaker.Lib.Elements"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Border Background="{DynamicResource CardBackgroundFillColorSecondaryBrush}"
            BorderBrush="{DynamicResource SurfaceStrokeColorDefaultBrush}"
            BorderThickness="1" CornerRadius="4" Padding="4">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="100"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <local:EnumValueView x:Name="_flagsView" Grid.Column="2"
                                 HorizontalAlignment="Stretch"
                                 VerticalAlignment="Center"/>
            <local:EnumValueView x:Name="_fileTypeView" Grid.Column="1"
                                 VerticalAlignment="Center" Margin="4,0"
                                 IsSelected="True"/>
            <local:MediaViewer x:Name="_preview" Margin="0,4,0,0"
                               Grid.Row="1" Grid.ColumnSpan="3"/>
            <local:EditableTextBlock x:Name="_idEditor" 
                                     FontSize="16" TextWrapping="Wrap"
                                     Text="{Binding Id}" Margin="2,0,2,6"/>
        </Grid>
    </Border>
</UserControl>
