<UserControl x:Class="DialogMaker.Lib.Elements.ListEditView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DialogMaker.Lib.Elements"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock x:Name="_placeholder" Margin="0,0,0,5"
                   FontWeight="Medium"/>
        <ListView x:Name="_itemsView" Grid.Row="1"
                  SelectionChanged="OnItemsViewSelectionChanged"
                   ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Label Content="{Binding View}"
                           Padding="0" HorizontalContentAlignment="Stretch"/>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
        <StackPanel Grid.Row="2" Orientation="Horizontal">
            <Button x:Name="_addButton" FontFamily="{StaticResource SymbolThemeFontFamily}"
                    Content="&#xE710;"
                    Click="OnAddButtonClicked"
                    ToolTip="Добавить объект"/>
            <Button x:Name="_removeButton" FontFamily="{StaticResource SymbolThemeFontFamily}"
                    Content="&#xE711;" Margin="5,0,0,0"
                    Click="OnRemoveButtonClicked"
                    ToolTip="Удалить объект"/>
        </StackPanel>
    </Grid>
</UserControl>
