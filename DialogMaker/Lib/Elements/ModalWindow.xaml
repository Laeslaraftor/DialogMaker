<Window x:Class="DialogMaker.Lib.Elements.ModalWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DialogMaker.Lib.Elements"
        mc:Ignorable="d" WindowStyle="None"
        Background="{DynamicResource SolidBackgroundFillColorBaseBrush}"
        Height="300" Width="450">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" GlassFrameThickness="20"/>
    </WindowChrome.WindowChrome>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="80"/>
        </Grid.RowDefinitions>
        <Label Background="{DynamicResource LayerOnMicaBaseAltFillColorTertiaryBrush}"
               x:Name="_content" Padding="0" HorizontalContentAlignment="Stretch"/>
        <Border Grid.Row="1" VerticalAlignment="Top"
                Height="1" Background="{DynamicResource SolidBackgroundFillColorSecondaryBrush}" />
        <Grid Grid.Row="1" Margin="25,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Button x:Name="_mainButton" Grid.ColumnSpan="3"
                    Style="{DynamicResource AccentButtonStyle}" 
                    HorizontalAlignment="Stretch" Padding="0,7,0,8"
                    Click="OnMainButtonClick"/>
            <Button x:Name="_secondaryButton" Grid.Column="2"
                    HorizontalAlignment="Stretch" Visibility="Collapsed"
                    Click="OnSecondaryButtonClick" Padding="0,7,0,8"/>
        </Grid>
    </Grid>
</Window>
