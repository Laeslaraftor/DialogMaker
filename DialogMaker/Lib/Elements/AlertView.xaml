<UserControl x:Class="DialogMaker.Lib.Elements.AlertView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DialogMaker.Lib.Elements"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <StackPanel Margin="18">
        <TextBlock x:Name="_title" FontSize="26"
                   FontWeight="Medium" TextWrapping="Wrap"/>
        <Label x:Name="_content" FontSize="16"
               Margin="0,8" Padding="0" 
               HorizontalContentAlignment="Stretch"/>
    </StackPanel>
</UserControl>
