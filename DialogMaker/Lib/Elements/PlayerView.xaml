<UserControl x:Class="DialogMaker.Lib.Elements.PlayerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DialogMaker.Lib.Elements"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <Border Grid.ColumnSpan="3" Grid.RowSpan="2"
                x:Name="_darkGradient" Visibility="Collapsed">
            <Border.Background>
                <RadialGradientBrush Center="0.5,1" GradientOrigin="0.5,1"
                                     RadiusX="0.5" RadiusY="1">
                    <GradientStop Color="#AF000000" Offset="0"/>
                    <GradientStop Color="#00000000" Offset="1"/>
                </RadialGradientBrush>
            </Border.Background>
        </Border>
        <Slider x:Name="_timeline" ValueChanged="OnTimelineValueChanged"
                Grid.ColumnSpan="3"/>
        <StackPanel Grid.Row="1" Orientation="Horizontal"
                    HorizontalAlignment="Left">
            <Button x:Name="_playButton"
                    FontFamily="{StaticResource SymbolThemeFontFamily}"
                    Click="OnPlayButtonClicked"/>
            <TextBlock x:Name="_timeText" VerticalAlignment="Center"
                       FontWeight="Normal" Margin="4,0"/>
        </StackPanel>
        <StackPanel Grid.Column="2" Grid.Row="1"
                    Orientation="Horizontal"
                    VerticalAlignment="Center">
            <TextBlock FontFamily="{StaticResource SymbolThemeFontFamily}"
                       Text="&#xE767;" VerticalAlignment="Center"/>
            <Slider x:Name="_volumeSlider" Maximum="1" Margin="6,0,0,0"
                    Width="60" MinWidth="0"
                    ValueChanged="OnVolumeSliderValueChanged"/>
        </StackPanel>
    </Grid>
</UserControl>
